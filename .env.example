# Public origin used for canonical, Open Graph, sitemap and robots URLs.
NEXT_PUBLIC_SITE_URL=https://mnats725-mnatronix-landing-328a.twc1.net

# Optional external POST endpoint. Without it, the form opens the visitor's email client.
NEXT_PUBLIC_CONTACT_FORM_ENDPOINT=

# Optional Cloudflare Turnstile widget. Secret verification belongs to the external endpoint.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Optional monitoring
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
